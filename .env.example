# TaskForge Environment Variables

# PostgreSQL
TASKFORGE_DB_HOST=localhost
TASKFORGE_DB_PORT=5432
TASKFORGE_DB_USER=taskforge
TASKFORGE_DB_PASSWORD=taskforge
TASKFORGE_DB_NAME=taskforge
TASKFORGE_DB_SSL_MODE=disable

# Redis
TASKFORGE_REDIS_ADDR=localhost:6379
TASKFORGE_REDIS_PASSWORD=
TASKFORGE_REDIS_DB=0

# Server
TASKFORGE_SERVER_PORT=8080
TASKFORGE_SERVER_READ_TIMEOUT=30s
TASKFORGE_SERVER_WRITE_TIMEOUT=30s

# Worker
TASKFORGE_WORKER_LEASE_DURATION=60s
TASKFORGE_WORKER_HEARTBEAT_INTERVAL=15s
TASKFORGE_WORKER_POLL_INTERVAL=1s

# Reaper
TASKFORGE_REAPER_INTERVAL=30s
TASKFORGE_REAPER_BATCH_SIZE=100

# Scheduler
TASKFORGE_SCHEDULER_INTERVAL=5s